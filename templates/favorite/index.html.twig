{% extends 'base.html.twig' %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/product.css') }}">
{% endblock %}

{% block body %}
<div class="my-products-header">
    <h1>Mes favoris</h1>
</div>

{% if favorites|length > 0 %}
    <div class="product-grid">
        {% for product in favorites %}
            <div class="product-card">
                {% if product.image %}
                    <img src="{{ asset('images/products/' ~ product.image) }}" alt="{{ product.name }}">
                {% else %}
                    <div class="no-image">Pas d'image</div>
                {% endif %}

                <div class="product-card-body">
                    <h3>{{ product.name }}</h3>
                    <p class="price">{{ product.price }} €</p>
                    <p class="category">{{ product.category.name }}</p>
                </div>

                <div class="product-actions">
                    <a href="{{ path('app_product_show', {id: product.id}) }}" class="btn">Voir</a>
                    <a href="{{ path('app_favorite_toggle', {id: product.id}) }}" class="btn btn-danger">Retirer</a>
                </div>
            </div>
        {% endfor %}
    </div>
{% else %}
    <div class="empty-state">
        <p>Tu n'as pas encore de favoris.</p>
    </div>
{% endif %}
{% endblock %}