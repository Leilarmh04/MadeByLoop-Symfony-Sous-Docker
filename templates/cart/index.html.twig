{% extends 'base.html.twig' %}

{% block title %}Mon panier{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/cart.css') }}">
{% endblock %}

{% block body %}

<div class="cart-page">
    <h1>Mon panier</h1>

    {% for message in app.flashes('success') %}
        <div class="flash-success">{{ message }}</div>
    {% endfor %}

    {% if cartProducts|length > 0 %}
        <div class="cart-items">
            {% for item in cartProducts %}
                <div class="cart-item">
                    <div class="cart-item-image">
                        {% if item.product.image %}
                            <img src="{{ asset('images/products/' ~ item.product.image) }}" alt="{{ item.product.name }}">
                        {% else %}
                            <div class="cart-no-image">Pas d'image</div>
                        {% endif %}
                    </div>

                    <div class="cart-item-info">
                        <a href="{{ path('app_product_show', {id: item.product.id}) }}" class="cart-item-name">{{ item.product.name }}</a>
                        <p class="cart-item-seller">par @{{ item.product.seller.username ?? item.product.seller.email }}</p>
                        <p class="cart-item-category">{{ item.product.category.name }}</p>
                    </div>

                    <div class="cart-item-quantity">
                        <a href="{{ path('app_cart_decrement', {id: item.product.id}) }}" class="qty-btn">−</a>
                        <span class="qty-value">{{ item.quantity }}</span>
                        <a href="{{ path('app_cart_increment', {id: item.product.id}) }}" class="qty-btn">+</a>
                    </div>

                    <div class="cart-item-price">
                        <span class="cart-item-subtotal">{{ item.subtotal|number_format(2, ',', ' ') }} €</span>
                        {% if item.quantity > 1 %}
                            <span class="cart-item-unit">{{ item.product.price|number_format(2, ',', ' ') }} € / unité</span>
                        {% endif %}
                    </div>

                    <div class="cart-item-actions">
                        <a href="{{ path('app_cart_remove', {id: item.product.id}) }}" class="cart-remove-btn" title="Supprimer">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <polyline points="3 6 5 6 21 6"/>
                                <path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/>
                            </svg>
                        </a>
                    </div>
                </div>
            {% endfor %}
        </div>

        <div class="cart-summary">
            <div class="cart-total">
                <span>Total</span>
                <span class="cart-total-price">{{ total|number_format(2, ',', ' ') }} €</span>
            </div>
            <div class="cart-actions">
                <a href="{{ path('app_cart_clear') }}" class="cart-clear-btn">Vider le panier</a>
                <a href="{{ path('app_checkout') }}" class="cart-checkout-btn">Commander</a>
                <a href="{{ path('app_shop') }}" class="cart-continue-btn">Continuer mes achats</a>
            </div>
        </div>

    {% else %}
        <div class="cart-empty">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1">
                <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
                <line x1="3" y1="6" x2="21" y2="6"/>
                <path d="M16 10a4 4 0 01-8 0"/>
            </svg>
            <h2>Votre panier est vide</h2>
            <p>Découvrez nos créations dans la boutique !</p>
            <a href="{{ path('app_shop') }}" class="btn">Voir la boutique</a>
        </div>
    {% endif %}
</div>

{% endblock %}
