{% extends 'base.html.twig' %}

{% block title %}Créer un compte{% endblock %}

{% block body %}

<h1>Créer un compte</h1>

{{ form_start(registrationForm) }}

{{ form_row(registrationForm.username, { label: "Nom d'utilisateur" }) }}
{{ form_row(registrationForm.email, { label: 'Adresse email' }) }}
{{ form_row(registrationForm.sellerRole) }}
{{ form_row(registrationForm.plainPassword.first, { label: 'Mot de passe' }) }}
{{ form_row(registrationForm.plainPassword.second, { label: 'Confirmer le mot de passe' }) }}

<button type="submit">Créer mon compte</button>

{{ form_end(registrationForm) }}

{% endblock %}