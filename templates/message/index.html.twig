{% extends 'base.html.twig' %}

{% block title %}Messages{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/message.css') }}">
{% endblock %}

{% block body %}
<div class="messaging-container">

    {# SIDEBAR - Liste des conversations #}
    <div class="conversations-sidebar">
        <div class="sidebar-header">
            <h2>Messages</h2>
        </div>

        <div class="conversations-list">
            {% if conversations|length > 0 %}
                {% for conv in conversations %}
                    {% set other = conv.getOtherUser(app.user) %}
                    {% set lastMsg = conv.getLastMessage() %}
                    {% set unreadCount = 0 %}
                    {% for msg in conv.messages %}
                        {% if msg.sender != app.user and not msg.isRead %}
                            {% set unreadCount = unreadCount + 1 %}
                        {% endif %}
                    {% endfor %}

                    <a href="{{ path('app_messages_show', {id: conv.id}) }}"
                       class="conversation-item {{ activeConversation and activeConversation.id == conv.id ? 'active' : '' }}">

                        <div class="conv-avatar">
                            {{ other.username|first|upper }}
                            {% if unreadCount > 0 %}
                                <span class="online-dot"></span>
                            {% endif %}
                        </div>

                        <div class="conv-info">
                            <div class="conv-top">
                                <span class="conv-name">{{ other.username ?? other.email }}</span>
                                <span class="conv-time">
                                    {% if lastMsg %}
                                        {{ lastMsg.sentAt|date('H:i') }}
                                    {% endif %}
                                </span>
                            </div>
                            <div class="conv-bottom">
                                <span class="conv-preview">
                                    {% if lastMsg %}
                                        {{ lastMsg.content|length > 35 ? lastMsg.content|slice(0, 35) ~ '...' : lastMsg.content }}
                                    {% else %}
                                        Aucun message
                                    {% endif %}
                                </span>
                                {% if unreadCount > 0 %}
                                    <span class="conv-badge">{{ unreadCount }}</span>
                                {% endif %}
                            </div>
                        </div>
                    </a>
                {% endfor %}
            {% else %}
                <div class="no-conversations">
                    <p>Pas encore de conversations.</p>
                    <p>Contactez un vendeur depuis la boutique !</p>
                </div>
            {% endif %}
        </div>
    </div>

    {# CHAT - Zone de messages #}
    <div class="chat-area">
        {% if activeConversation %}
            {% set other = activeConversation.getOtherUser(app.user) %}

            {# Chat header #}
            <div class="chat-header">
                <div class="chat-header-user">
                    <div class="chat-avatar">
                        {{ other.username|first|upper }}
                    </div>
                    <div>
                        <div class="chat-username">{{ other.username ?? other.email }}</div>
                    </div>
                </div>
            </div>

            {# Messages #}
            <div class="chat-messages" id="chatMessages">
                {% for message in activeConversation.messages %}
                    <div class="message {{ message.sender == app.user ? 'message-me' : 'message-other' }}">
                        <div class="message-bubble">
                            {{ message.content }}
                            <span class="message-time">{{ message.sentAt|date('H:i') }}</span>
                        </div>
                    </div>
                {% endfor %}
            </div>

            {# Input #}
            <div class="chat-input">
                <form method="post" action="{{ path('app_messages_show', {id: activeConversation.id}) }}" class="chat-form">
                    <input type="text" name="content" placeholder="Écrire un message..." autocomplete="off" required>
                    <button type="submit">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
                            <path d="M22 2L11 13"/>
                            <path d="M22 2L15 22L11 13L2 9L22 2Z"/>
                        </svg>
                    </button>
                </form>
            </div>

        {% else %}
            <div class="chat-empty">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1">
                    <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>
                </svg>
                <p>Sélectionnez une conversation</p>
            </div>
        {% endif %}
    </div>

</div>

<script>
    const chat = document.getElementById('chatMessages');
    if (chat) chat.scrollTop = chat.scrollHeight;
</script>
{% endblock %}