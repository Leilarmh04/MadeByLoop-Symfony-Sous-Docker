{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/auth.css') }}">
{% endblock %}

{% block body %}
<div class="auth-container">
    <h1>Connexion</h1>

    {% if error %}
        <div class="auth-error">
            {{ error.messageKey | trans(error.messageData, 'security') }}
        </div>
    {% endif %}

    <form method="post" action="{{ path('app_login') }}" class="auth-form">

        <div class="form-group">
            <label for="inputEmail">Email</label>
            <input type="email" name="email" id="inputEmail" class="form-input" value="{{ last_username }}" required autofocus>
        </div>

        <div class="form-group">
            <label for="inputPassword">Mot de passe</label>
            <input type="password" name="password" id="inputPassword" class="form-input" required>
        </div>

        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

        <button type="submit" class="btn-auth">Se connecter</button>

    </form>

    <p class="auth-link">Tu n'as pas de compte ? <a href="{{ path('app_register') }}">S'inscrire</a></p>
</div>
{% endblock %}