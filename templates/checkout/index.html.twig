{% extends 'base.html.twig' %}

{% block title %}Paiement{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/checkout.css') }}">
{% endblock %}

{% block body %}

<div class="checkout-page">

    {# ===== COLONNE GAUCHE : FORMULAIRE ===== #}
    <div class="checkout-form-section">
        <h1>Paiement</h1>

        <form method="post" action="{{ path('app_checkout') }}" class="checkout-form">

            {# Nom / Prénom #}
            <div class="form-row">
                <div class="form-group">
                    <label for="lastname">Nom</label>
                    <input type="text" id="lastname" name="lastname" placeholder="Dupont" class="form-input">
                </div>
                <div class="form-group">
                    <label for="firstname">Prénom</label>
                    <input type="text" id="firstname" name="firstname" placeholder="Gérard" class="form-input">
                </div>
            </div>

            {# Email #}
            <div class="form-group">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" placeholder="ex.gérard@gmail.com" value="{{ app.user.email }}" class="form-input">
            </div>

            {# Adresse de livraison #}
            <div class="form-group">
                <div class="label-row">
                    <label for="address">Adresse de livraison</label>
                    <span class="label-hint">Obligatoire</span>
                </div>
                <input type="text" id="address" name="address" placeholder="10 rue..." class="form-input">
            </div>

            {# Ville / Code postal #}
            <div class="form-row">
                <div class="form-group">
                    <label for="city">Ville</label>
                    <input type="text" id="city" name="city" placeholder="Paris" class="form-input">
                </div>
                <div class="form-group">
                    <label for="zipcode">Code postal</label>
                    <input type="text" id="zipcode" name="zipcode" placeholder="75000" class="form-input">
                </div>
            </div>

            {# Pays #}
            <div class="form-group">
                <label for="country">Pays</label>
                <select id="country" name="country" class="form-input">
                    <option value="FR" selected>France</option>
                    <option value="BE">Belgique</option>
                    <option value="CH">Suisse</option>
                    <option value="LU">Luxembourg</option>
                </select>
            </div>

            {# ========== MOYEN DE PAIEMENT — COMMENTÉ POUR PLUS TARD ==========
            <div class="payment-section">
                <div class="label-row">
                    <label>Moyen de paiement</label>
                    <span class="label-hint">Démo</span>
                </div>

                <div class="payment-methods">
                    <label class="payment-option active">
                        <input type="radio" name="payment_method" value="card" checked>
                        <span>Carte bancaire</span>
                    </label>
                    <label class="payment-option">
                        <input type="radio" name="payment_method" value="paypal">
                        <span>PayPal (démo)</span>
                    </label>
                </div>

                <div class="form-group">
                    <label for="card_name">Nom sur la carte</label>
                    <input type="text" id="card_name" name="card_name" placeholder="NOM PRÉNOM" class="form-input">
                </div>

                <div class="form-row form-row-card">
                    <div class="form-group" style="flex:2">
                        <label for="card_number">Numéro de carte</label>
                        <input type="text" id="card_number" name="card_number" placeholder="1234 5678 9012 3456" class="form-input" maxlength="19">
                    </div>
                    <div class="form-group">
                        <label for="card_exp">Date (MM/AA)</label>
                        <input type="text" id="card_exp" name="card_exp" placeholder="06/28" class="form-input" maxlength="5">
                    </div>
                    <div class="form-group">
                        <label for="card_cvc">CVC</label>
                        <input type="text" id="card_cvc" name="card_cvc" placeholder="123" class="form-input" maxlength="3">
                    </div>
                </div>
            </div>
            ========== FIN MOYEN DE PAIEMENT #}

            {# Boutons #}
            <div class="checkout-actions">
                <a href="{{ path('app_cart') }}" class="checkout-back">Retour au panier</a>

                {# ===== BOUTON PAYER — COMMENTÉ POUR PLUS TARD =====
                <button type="submit" class="checkout-pay-btn">Payer</button>
                ========== FIN BOUTON PAYER #}
            </div>

        </form>
    </div>

    {# ===== COLONNE DROITE : RÉSUMÉ ===== #}
    <div class="checkout-summary">
        <h2>Panier <span class="summary-count">{{ cartProducts|length }} article{{ cartProducts|length > 1 ? 's' : '' }}</span></h2>

        <div class="summary-items">
            {% for item in cartProducts %}
                <div class="summary-item">
                    <div class="summary-item-image">
                        {% if item.product.image %}
                            <img src="{{ asset('images/products/' ~ item.product.image) }}" alt="{{ item.product.name }}">
                        {% else %}
                            <div class="summary-no-image">Image</div>
                        {% endif %}
                    </div>
                    <div class="summary-item-info">
                        <span class="summary-item-name">{{ item.product.name }}</span>
                        <span class="summary-item-detail">Quantité : {{ item.quantity }}</span>
                    </div>
                    <span class="summary-item-price">{{ item.subtotal|number_format(2, ',', ' ') }} €</span>
                </div>
            {% endfor %}
        </div>

        <div class="summary-totals">
            <div class="summary-line">
                <span>Sous-total</span>
                <span>{{ subtotal|number_format(2, ',', ' ') }} €</span>
            </div>
            <div class="summary-line">
                <span>Livraison</span>
                <span>{{ shipping|number_format(2, ',', ' ') }} €</span>
            </div>

            {# ===== CODE PROMO — COMMENTÉ POUR PLUS TARD =====
            <div class="summary-line">
                <span>Code promo</span>
                <span>—</span>
            </div>
            <div class="promo-input">
                <input type="text" name="promo_code" placeholder="Code promo" class="form-input">
                <button type="button" class="promo-btn">Appliquer</button>
            </div>
            ========== FIN CODE PROMO #}

            <div class="summary-total-line">
                <span>Total</span>
                <span class="summary-total-price">{{ total|number_format(2, ',', ' ') }} €</span>
            </div>
        </div>
    </div>

</div>

{% endblock %}
