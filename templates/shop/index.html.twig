{% extends 'base.html.twig' %}

{% block title %}Boutique{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/shop.css') }}">
{% endblock %}

{% block body %}

<div class="shop-hero">
    {% if app.user %}
        <h1>Boutique</h1>
    {% else %}
        <h1>Boutique</h1>
    {% endif %}
    <p>Découvre des créations au crochet faites à la main.</p>
</div>

{% if products|length > 0 %}
    <div class="shop-grid">
        {% for product in products %}
            <div class="product-card">
                <a href="{{ path('app_product_show', {id: product.id}) }}" class="card-image-link">
                    {% if product.image %}
                        <img src="{{ asset('images/products/' ~ product.image) }}" alt="{{ product.name }}">
                    {% else %}
                        <div class="card-no-image">Pas d'image</div>
                    {% endif %}
                </a>

                <div class="card-body">
                    <a href="{{ path('app_profile_public', {id: product.seller.id}) }}" class="card-boutique">
                        @{{ product.seller.username ?? product.seller.email }}
                    </a>
                    <a href="{{ path('app_product_show', {id: product.id}) }}" class="card-name">{{ product.name }}</a>
                    <span class="card-price">{{ product.price }} €</span>

                    <div class="card-bottom">
                        <span class="card-category">{{ product.category.name }}</span>
                        {% if app.user %}
                            <a href="{{ path('app_cart_add', {id: product.id}) }}" class="card-cart-btn" title="Ajouter au panier">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
                                    <line x1="3" y1="6" x2="21" y2="6"/>
                                    <path d="M16 10a4 4 0 01-8 0"/>
                                </svg>
                            </a>
                        {% endif %}
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
{% else %}
    <div class="shop-empty">
        <p>Aucun produit disponible pour le moment.</p>
    </div>
{% endif %}

{% endblock %}
