{% extends 'base.html.twig' %}

{% block title %}Inscription{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/auth.css') }}">
{% endblock %}

{% block body %}

<div class="auth-container">
    <h1>Inscrivez vous</h1>

    {{ form_start(registrationForm, {'attr': {'class': 'auth-form', 'novalidate': 'novalidate'}}) }}

        <div class="form-group">
            {{ form_label(registrationForm.username, "Nom d'utilisateur") }}
            {{ form_widget(registrationForm.username, {'attr': {'class': 'form-input'}}) }}
            {{ form_errors(registrationForm.username) }}
        </div>

        <div class="form-group">
            {{ form_label(registrationForm.email, "Email") }}
            {{ form_widget(registrationForm.email, {'attr': {'class': 'form-input'}}) }}
            {{ form_errors(registrationForm.email) }}
        </div>

        <div class="form-group">
            <label>Je souhaite...</label>
            <div class="seller-role-group">
                {% for child in registrationForm.sellerRole %}
                    <label>
                        {{ form_widget(child) }}
                        {{ child.vars.label }}
                    </label>
                {% endfor %}
            </div>
            {{ form_errors(registrationForm.sellerRole) }}
        </div>

        <div class="form-group">
            {{ form_label(registrationForm.plainPassword.first, "Mot de passe") }}
            {{ form_widget(registrationForm.plainPassword.first, {'attr': {'class': 'form-input'}}) }}
            {{ form_errors(registrationForm.plainPassword.first) }}
        </div>

        <div class="form-group">
            {{ form_label(registrationForm.plainPassword.second, "Confirmer le mot de passe") }}
            {{ form_widget(registrationForm.plainPassword.second, {'attr': {'class': 'form-input'}}) }}
            {{ form_errors(registrationForm.plainPassword.second) }}
        </div>

        <button type="submit" class="btn-auth">S'inscrire</button>

    {{ form_end(registrationForm) }}

    <p class="auth-link">Vous avez déjà un compte ? <a href="{{ path('app_login') }}">Se connecter</a></p>
</div>

{% endblock %}