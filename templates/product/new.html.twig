{% extends 'base.html.twig' %}

{% block title %}Ajouter un produit{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/new-product.css') }}">
{% endblock %}

{% block body %}
<div class="container">
    <h1>Ajouter un produit</h1>

    {{ form_start(form) }}
        {{ form_widget(form) }}
        <button type="submit" class="btn">Ajouter</button>
    {{ form_end(form) }}

    <a href="{{ path('app_my_products') }}">← Retour à mes produits</a>
</div>
{% endblock %}